# Supabase
# Project URL and service role key from Settings > API in your Supabase project.
# The service role key bypasses Row Level Security and must only ever be used
# from this trusted Electron main process — never ship it to the renderer.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Application
APP_NAME="Inventory Management System"
APP_VERSION="1.0.0"

# Session
SESSION_SECRET="change-this-to-a-secure-random-string"

# Logging
LOG_LEVEL="info"

# Backup
BACKUP_PATH="./backups"
AUTO_BACKUP_ENABLED="true"
AUTO_BACKUP_INTERVAL_HOURS="24"
